# Secrets - NEVER commit
.env
*.key
*.pem
google_token.json
credentials.json

# Generated configs (machine-specific, created by setup.sh / start_jarvis.sh)
config/mcp-observer.json
mcp-opencode-observer/.env
jarvis/config/jarvis.yaml
# Claude Code MCP settings — machine-specific absolute paths, regenerated on every start
.claude/settings.json

# Runtime data (lives in JARVIS_HOME, not repo)
# JARVIS_HOME/ is the portable template — keep structure, ignore real data
JARVIS_HOME/ACCOUNTS/*/
!JARVIS_HOME/ACCOUNTS/_template/
!JARVIS_HOME/ACCOUNTS/.gitkeep
JARVIS_HOME/MEETINGS/*
!JARVIS_HOME/MEETINGS/.gitkeep
JARVIS_HOME/logs/*
!JARVIS_HOME/logs/.gitkeep
JARVIS_HOME/recordings/*
!JARVIS_HOME/recordings/.gitkeep
JARVIS_HOME/data/*
!JARVIS_HOME/data/.gitkeep
# Brain file — real content is personal, keep blank template
JARVIS_HOME/JARVIS_BRAIN.md
!JARVIS_HOME/.gitkeep

# Legacy paths
ACCOUNTS/
MEMORY/
logs/
recordings/
data/backups/
data/meeting_queue/
data/notifications.json
data/sync_state.json

# Media files
*.mp4
*.wav
*.m4a
*.webm
*.mp3
*.ogg

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
.Python
build/
dist/
develop-eggs/
eggs/
sdist/
var/
wheels/
venv/
.venv/
ENV/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
mcp-jarvis-server/dist/
mcp-opencode-observer/dist/

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db

# IDEs
.idea/
.vscode/
*.swp
*.swo

# JARVIS runtime
.ui.pid
.mcp_pid
.mcp_observer.pid
.jarvis.pid
jarvis/data/archives/
jarvis/data/history/
jarvis/data/cache/
