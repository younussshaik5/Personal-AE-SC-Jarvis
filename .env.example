# JARVIS v2 - Personal AE + SC Sales Assistant
# Copy this to .env and fill in your API keys

# NVIDIA API Key (PRIMARY - used for all background LLM processing)
# Get from: https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_api_key_here

# Anthropic API Key (FALLBACK - used only when you interact via Claude Desktop)
# Only needed if you want Claude as fallback LLM
ANTHROPIC_API_KEY=

# JARVIS home directory (where your deal data is stored, outside the repo)
# Default: ~/JARVIS
JARVIS_HOME=

# Claude workspace directory — the folder where you use Claude Desktop / Claude Code
# JARVIS watches this folder so KnowledgeBuilder can extract intelligence from any
# file you work on with Claude (notes, RFPs, emails, anything)
# Set this to wherever YOU keep your Claude workspace. Examples:
#   CLAUDE_SPACE=/Users/yourname/Documents/claude-work
#   CLAUDE_SPACE=/Users/yourname/projects/work
# Leave empty to disable claude space watching
CLAUDE_SPACE=

# Optional: Telegram bot for mobile notifications
TELEGRAM_BOT_TOKEN=
