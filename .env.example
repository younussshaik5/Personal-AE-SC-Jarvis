# JARVIS Environment Configuration Example

# Telegram Bot Token (Get from @BotFather)
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# LLM Configuration (If using OpenAI-compatible APIs instead of OpenCode integration)
LLM_PROVIDER=openai
LLM_API_KEY=YOUR_API_KEY_HERE
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
