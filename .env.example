# JARVIS v2 - Personal AE + SC Sales Assistant
# Copy this to .env and fill in your API keys

# ── NVIDIA API KEY POOL ──────────────────────────────────────────────────────
# Primary LLM provider — Kimi K2 Thinking via NVIDIA NIM
# Get keys from: https://build.nvidia.com/ (free tier available)
# Add multiple keys for round-robin rotation under parallel load.
# Rate-limited key → auto-rotates to the next one seamlessly.
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_API_KEY_2=
NVIDIA_API_KEY_3=
NVIDIA_API_KEY_4=
NVIDIA_API_KEY_5=

# ── OPTIONAL ─────────────────────────────────────────────────────────────────
# Anthropic API Key (only needed if you use Claude API directly, not Claude Desktop)
ANTHROPIC_API_KEY=

# JARVIS home directory (where your deal data lives, outside the repo)
JARVIS_HOME=

# Claude workspace directory — JARVIS watches this for deal intelligence
CLAUDE_SPACE=

# Optional: Telegram bot for mobile notifications
TELEGRAM_BOT_TOKEN=
