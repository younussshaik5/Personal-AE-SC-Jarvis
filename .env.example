# JARVIS v2 - Personal AE + SC Sales Assistant
# Copy this to .env and fill in your API keys

# ── REQUIRED ──────────────────────────────────────────────────────────────────
# NVIDIA API Key — primary LLM provider (all skills use this)
# Get from: https://build.nvidia.com/ (free tier available)
# Models used:
#   meta/llama-3.3-70b-instruct       → default / reasoning tasks
#   nvidia/nemotron-3-nano-30b-a3b    → text gen / summary / rephrase (long context)
#   meta/llama-3.1-8b-instruct        → fast / quick tasks
NVIDIA_API_KEY=your_nvidia_api_key_here

# ── OPTIONAL FALLBACK PROVIDERS ───────────────────────────────────────────────
# JARVIS automatically falls back to these if all NVIDIA models are rate-limited.
# Leave blank to skip — no errors, just one less safety net.

# Groq — extremely fast Llama inference, generous free tier
# Get from: https://console.groq.com/
GROQ_API_KEY=

# Together AI — reliable fallback for Llama models
# Get from: https://api.together.xyz/
TOGETHER_API_KEY=

# ── JARVIS PATHS ──────────────────────────────────────────────────────────────
# Anthropic API Key (only needed if you use Claude API directly, not Claude Desktop)
ANTHROPIC_API_KEY=

# JARVIS home directory (where your deal data lives, outside the repo)
JARVIS_HOME=

# Claude workspace directory — set to wherever you keep your Claude work files
# JARVIS watches this folder for deal intelligence (notes, RFPs, emails, etc.)
# Leave empty to disable
CLAUDE_SPACE=

# Optional: Telegram bot for mobile notifications
TELEGRAM_BOT_TOKEN=
