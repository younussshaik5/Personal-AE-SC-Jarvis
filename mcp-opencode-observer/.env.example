# OpenCode Observer Configuration
# All paths are auto-detected by setup.sh — edit only if needed

# OpenCode database path (auto-detected per OS)
# macOS: ~/Library/Application Support/Accomplish/opencode/opencode.db
# Linux: ~/.local/share/opencode/opencode.db
OPENCODE_DB_PATH=

# OpenCode tool output directory (auto-detected)
OPENCODE_TOOL_OUTPUT_DIR=

# Server ports (change if ports are in use)
OPENCODE_OBSERVER_PORT=3000
OPENCODE_OBSERVER_WS_PORT=3001

# Polling interval in milliseconds
OPENCODE_OBSERVER_POLL_INTERVAL=1000